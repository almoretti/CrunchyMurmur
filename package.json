{
  "name": "crunchymurmur",
  "productName": "CrunchyMurmur",
  "desktopName": "CrunchyMurmur",
  "version": "0.1.0",
  "description": "Cross-platform local voice dictation, meeting transcription, activity statistics, and AI notes for Windows, macOS, and Linux.",
  "author": "almoretti and contributors",
  "license": "MIT",
  "homepage": "https://github.com/a-streetcoder/CrunchyMurmur#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a-streetcoder/CrunchyMurmur.git"
  },
  "bugs": {
    "url": "https://github.com/a-streetcoder/CrunchyMurmur/issues"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "main": "src/main.js",
  "private": true,
  "scripts": {
    "build:editor": "node scripts/build-editor.js",
    "build:transcriber": "node scripts/prepare-transcriber-runtime.js",
    "start": "npm run build:editor && npm run build:transcriber && node scripts/ensure-macos-native.js && electron .",
    "dev:permissions": "electron scripts/dev-macos-permissions.js",
    "lint": "npm run build:editor && node scripts/check-js.js",
    "test": "node --test test/*.test.js",
    "test:e2e": "npm run build:editor && node --test test/e2e/electron.test.js",
    "check:docs": "node scripts/check-doc-links.js",
    "check:i18n": "node scripts/check-i18n.js",
    "check:repo": "node scripts/check-repository-links.js",
    "smoke:packaged": "node scripts/smoke-packaged.js",
    "verify:update-manifests": "node scripts/verify-update-manifest.js",
    "check": "npm run lint && npm test && npm run check:docs && npm run check:i18n && npm run check:repo",
    "release:check": "node scripts/check-release.js",
    "prepare:whisper:win": "node scripts/prepare-whisper-runtime.js --platform win32 --arch all",
    "prepare:whisper:mac": "node scripts/prepare-whisper-runtime.js --platform darwin --arch universal",
    "prepare:whisper:linux": "node scripts/prepare-whisper-runtime.js --platform linux --arch all",
    "prepare:transcriber:win": "node scripts/prepare-transcriber-runtime.js --platform win32 --arch all",
    "prepare:transcriber:mac": "node scripts/prepare-transcriber-runtime.js --platform darwin --arch universal",
    "prepare:transcriber:linux": "node scripts/prepare-transcriber-runtime.js --platform linux --arch all",
    "pack:win": "npm run build:editor && node scripts/prepare-whisper-runtime.js --platform win32 --arch x64 && node scripts/prepare-transcriber-runtime.js --platform win32 --arch x64 && electron-builder --dir --win --x64",
    "build:win": "npm run build:editor && npm run prepare:whisper:win && npm run prepare:transcriber:win && electron-builder --win",
    "build:mac": "npm run build:editor && bash scripts/prepare-macos-icon.sh && bash scripts/build-macos-native.sh && npm run prepare:whisper:mac && npm run prepare:transcriber:mac && electron-builder --mac",
    "build:linux": "npm run build:editor && bash scripts/prepare-linux-icons.sh && npm run prepare:whisper:linux && npm run prepare:transcriber:linux && electron-builder --linux --publish never && node scripts/normalize-linux-artifacts.js"
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "node-ical": "^0.26.1",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.3",
    "@muyajs/core": "0.2.0",
    "@playwright/test": "^1.61.1",
    "acorn": "^8.17.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1"
  },
  "build": {
    "appId": "cc.moretti.crunchymurmur.desktop",
    "productName": "CrunchyMurmur",
    "files": [
      "src/**/*",
      "ui/**/*",
      "assets/icon-palette.ico",
      "assets/tray-palette.png",
      "assets/brand-mark.png",
      "assets/brand-mark.svg",
      "LICENSE",
      "docs/legal/privacy.md",
      "docs/legal/terms.md",
      "docs/THIRD_PARTY_NOTICES.md",
      "README.md",
      "CHANGELOG.md"
    ],
    "extraResources": [
      {
        "from": "docs/legal/privacy.md",
        "to": "PRIVACY.md"
      },
      {
        "from": "docs/legal/terms.md",
        "to": "TERMS.md"
      },
      {
        "from": "LICENSE",
        "to": "LICENSE"
      },
      {
        "from": "docs/THIRD_PARTY_NOTICES.md",
        "to": "THIRD_PARTY_NOTICES.md"
      },
      {
        "from": "build/whisper-runtime/${os}-${arch}",
        "to": "native/whisper"
      },
      {
        "from": "build/transcriber-runtime/${os}-${arch}",
        "to": "native/transcriber"
      }
    ],
    "asar": true,
    "npmRebuild": false,
    "afterPack": "scripts/after-pack.js",
    "artifactName": "${productName}-${os}-${arch}.${ext}",
    "publish": {
      "provider": "github",
      "owner": "a-streetcoder",
      "repo": "CrunchyMurmur",
      "releaseType": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon-palette.ico",
      "signExts": [
        ".exe",
        ".dll",
        ".node"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "CrunchyMurmur"
    },
    "mac": {
      "minimumSystemVersion": "13.0",
      "extraResources": [
        {
          "from": "build/native/CrunchyMurmurNative",
          "to": "native/CrunchyMurmurNative"
        },
        {
          "from": "build/whisper-runtime/mac-universal",
          "to": "native/whisper"
        },
        {
          "from": "build/transcriber-runtime/mac-universal",
          "to": "native/transcriber"
        }
      ],
      "x64ArchFiles": "Contents/Resources/native/transcriber/*.dylib",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "notarize": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "CrunchyMurmur uses the microphone only while you explicitly record dictation or a meeting.",
        "NSAudioCaptureUsageDescription": "CrunchyMurmur captures system audio only when you explicitly start a meeting recording, so other participants can be transcribed.",
        "NSCalendarsFullAccessUsageDescription": "CrunchyMurmur reads upcoming calendar events so you can start and name meeting recordings from your schedule.",
        "NSAppleEventsUsageDescription": "CrunchyMurmur uses System Events only to paste your completed transcription into the focused application."
      }
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icons",
      "category": "Utility",
      "synopsis": "Private voice dictation and AI notes",
      "description": "Cross-platform local voice dictation, meeting transcription, activity statistics, and AI-generated notes.",
      "maintainer": "almoretti",
      "vendor": "CrunchyMurmur",
      "desktop": {
        "entry": {
          "Name": "CrunchyMurmur",
          "Comment": "Voice dictation and AI notes",
          "Categories": "Utility;AudioVideo;",
          "Keywords": "dictation;whisper;transcription;notes;",
          "StartupWMClass": "CrunchyMurmur"
        }
      }
    }
  }
}
